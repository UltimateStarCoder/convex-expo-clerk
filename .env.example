# Convex local development
CONVEX_DEPLOYMENT=dev:your-deployment-name
EXPO_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
EXPO_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site

# Clerk client configuration
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-publishable-key

# Clerk server-side tooling only. Never prefix this with EXPO_PUBLIC_.
CLERK_SECRET_KEY=sk_test_your-secret-key

# Set the Clerk issuer on the Convex deployment rather than in Expo:
# npx convex env set CLERK_FRONTEND_API_URL https://your-instance.clerk.accounts.dev
